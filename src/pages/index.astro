---
import Layout from '../layouts/Layout.astro';
---

<Layout title="NAMENLOS TATTOO • PAIN • CHAOS • ANARCHY">

  <style>
    body {
      margin: 0;
      overflow-x: hidden;
      background:
        linear-gradient(rgba(10,10,10,0.88), rgba(10,10,10,0.88)),
        url('/images/bg/main-bg.svg');
      background-size: cover;
      background-attachment: fixed;
      background-position: center;
      color: white;
      font-family: Arial, Helvetica, sans-serif;
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 999;
      background-image:
        radial-gradient(circle at 20% 20%, rgba(0,0,0,0.08) 1px, transparent 1px),
        radial-gradient(circle at 80% 80%, rgba(0,0,0,0.08) 1px, transparent 1px);
      background-size: 3px 3px;
      opacity: 0.35;
      mix-blend-mode: multiply;
    }

    body::after {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 998;
      background: repeating-linear-gradient(
        120deg,
        transparent 0px,
        transparent 80px,
        rgba(0,0,0,0.03) 81px,
        transparent 82px
      );
      opacity: 0.25;
    }

    .punk-title {
      font-weight: 900;
      letter-spacing: -0.06em;
      line-height: 0.9;
      text-transform: uppercase;
      text-shadow:
        6px 6px 0px rgba(139,0,0,0.8),
        -3px -3px 0px rgba(0,0,0,0.8);
    }

    .trash-bg {
      position: relative;
      background:
        linear-gradient(rgba(15,15,15,0.93), rgba(15,15,15,0.93)),
        url('/images/bg/main-bg.svg');
      background-size: cover;
      background-position: center;
      overflow: hidden;
    }

    .trash-bg::before {
      content: "";
      position: absolute;
      inset: 0;
      background: repeating-linear-gradient(
        -45deg,
        transparent 0px,
        transparent 40px,
        rgba(255,255,255,0.03) 41px,
        transparent 42px
      );
      opacity: 0.3;
      pointer-events: none;
    }

    .trash-bg::after {
      content: "";
      position: absolute;
      width: 600px;
      height: 600px;
      background: radial-gradient(circle, rgba(139,0,0,0.35), transparent 70%);
      top: -200px;
      right: -200px;
      filter: blur(40px);
      pointer-events: none;
    }

    .sticker {
      position: absolute;
      background: white;
      color: black;
      padding: 10px 14px;
      font-weight: 900;
      transform: rotate(-8deg);
      border: 4px solid black;
      z-index: 10;
      mix-blend-mode: screen;
    }

    .chain {
      position: absolute;
      opacity: 0.08;
      font-size: 220px;
      pointer-events: none;
      font-weight: 900;
    }

    .drip {
      position: absolute;
      width: 12px;
      background: #8b0000;
      border-radius: 0 0 30px 30px;
      filter: blur(1px);
    }

    img {
      filter: contrast(1.08) saturate(0.9) grayscale(0.05);
    }

    .portfolio-img {
      transition: 0.35s ease;
    }

    .portfolio-img:hover {
      transform: translateY(-8px) rotate(-1deg) scale(1.02);
      filter: contrast(1.15);
      box-shadow: 0 0 40px rgba(139,0,0,0.6);
    }

    .btn-chaos {
      position: relative;
      overflow: hidden;
    }

    .btn-chaos::before {
      content: "";
      position: absolute;
      inset: 0;
      background: repeating-linear-gradient(
        -45deg,
        transparent 0px,
        transparent 8px,
        rgba(0,0,0,0.08) 9px,
        transparent 10px
      );
      opacity: 0.5;
    }

    .project-card {
      position: relative;
      background: rgba(15,0,0,0.92);
      border: 4px solid #7f1d1d;
      padding: 2.5rem;
      overflow: hidden;
      transition: border-color 0.3s;
    }

    .project-card::after {
      content: "";
      position: absolute;
      width: 300px;
      height: 300px;
      background: radial-gradient(circle, rgba(139,0,0,0.2), transparent 70%);
      bottom: -100px;
      right: -100px;
      filter: blur(30px);
      pointer-events: none;
    }

    .project-card:hover {
      border-color: #dc2626;
    }
  </style>

  <!-- HERO -->
  <section class="min-h-screen flex items-center pt-28 relative overflow-hidden">

    <video autoplay muted loop playsinline
      class="absolute inset-0 w-full h-full object-cover opacity-30">
      <source src="/videos/bg.mp4" type="video/mp4" />
    </video>

    <div class="absolute inset-0 bg-black/65"></div>

    <div class="chain top-[-40px] left-[-20px]">⛓</div>
    <div class="chain bottom-[-80px] right-[0px] rotate-12">⛓</div>

    <div class="sticker top-[130px] left-[40px] hidden md:block">NO FUTURE</div>
    <div class="sticker bottom-[120px] right-[60px] hidden md:block rotate-6">DIY OR DIE</div>

    <div class="drip h-[180px] top-0 left-[15%]"></div>
    <div class="drip h-[260px] top-0 left-[50%]"></div>
    <div class="drip h-[120px] top-0 right-[20%]"></div>

    <div class="max-w-6xl mx-auto px-6 text-center relative z-10">
      <h1 class="punk-title text-7xl md:text-[10rem] mb-6">NAMENLOS</h1>
      <p class="text-5xl md:text-7xl text-red-700 font-black mb-8 tracking-tight">PAIN IS MY INK</p>
      <p class="text-2xl md:text-4xl max-w-3xl mx-auto leading-tight">
        <span class="ru">Я выжигаю свободу на коже.<br />Без правил. Без компромиссов.</span>
        <span class="de">Ich brenne Freiheit in die Haut.<br />Keine Regeln. Keine Kompromisse.</span>
      </p>
      <div class="mt-12">
        <a href="https://t.me/namenlostattoo" target="_blank" rel="noopener"
          class="btn-chaos inline-block border-4 border-red-700 hover:bg-red-700 text-2xl font-black px-12 py-6 transition-all">
          <span class="ru">ЗАБИТЬСЯ НА СЕАНС →</span>
          <span class="de">SESSION BUCHEN →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section id="about" class="py-24 md:py-32 trash-bg border-t-8 border-red-900 relative">
    <div class="max-w-6xl mx-auto px-6 relative z-10">

      <h2 class="text-6xl md:text-8xl font-black text-center mb-20 text-red-700">
        <span class="ru">ОБО МНЕ</span>
        <span class="de">ÜBER MICH</span>
      </h2>

      <div class="grid md:grid-cols-2 gap-16 items-center">
        <div>
          <img src="https://files.grok.x.ai/generated/qghMf.jpg"
            class="w-full border-8 border-red-900 mb-6" alt="Namenlos" />
          <div class="grid grid-cols-3 gap-4">
            <img src="https://files.grok.x.ai/generated/GzQYl.jpg" class="w-full border-4 border-red-900" alt="" />
            <img src="https://files.grok.x.ai/generated/K5yuB.jpg" class="w-full border-4 border-red-900" alt="" />
            <img src="https://files.grok.x.ai/generated/eKyuk.jpg" class="w-full border-4 border-red-900" alt="" />
          </div>
        </div>

        <div class="space-y-10 text-xl md:text-2xl leading-relaxed">
          <p>
            <span class="ru">Я колю там, где другие боятся — на кинк-вечеринках, в подвалах и на рейвах под тяжёлый бас.</span>
            <span class="de">Ich steche dort, wo andere Angst haben — auf Kink-Partys, in Kellern und auf Raves unter schwerem Bass.</span>
          </p>
          <p class="italic border-l-8 border-yellow-500 pl-8">
            <span class="ru">"Если тебе нужна красивая картинка — иди к другим. Ко мне приходят те, кто хочет чувствовать боль и свободу."</span>
            <span class="de">"Wenn du ein schönes Bild willst — geh woanders hin. Zu mir kommen die, die Schmerz und Freiheit spüren wollen."</span>
          </p>
          <p>
            <span class="ru">Без стерильных студий. Только честная кровь, цепи и булавки.</span>
            <span class="de">Keine sterilen Studios. Nur echtes Blut, Ketten und Nadeln.</span>
          </p>
          <div class="text-5xl font-black border-l-8 border-red-700 pl-8 leading-none">
            NO GODS<br />NO MASTERS<br />ONLY CHAOS
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PORTFOLIO -->
  <section id="portfolio" class="py-24 md:py-32 border-t-8 border-red-900 relative">
    <div class="absolute inset-0 bg-white/5"></div>
    <div class="max-w-7xl mx-auto px-6 relative z-10">
      <h2 class="text-6xl md:text-8xl font-black text-center mb-20 text-red-700">PORTFOLIO</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-6 md:gap-8">
        <img src="https://files.grok.x.ai/generated/ir6M6.jpg" class="portfolio-img w-full border-8 border-red-900" alt="" />
        <img src="https://files.grok.x.ai/generated/RCg4J.jpg" class="portfolio-img w-full border-8 border-red-900" alt="" />
        <img src="https://files.grok.x.ai/generated/vwRs5.jpg" class="portfolio-img w-full border-8 border-red-900" alt="" />
        <img src="https://files.grok.x.ai/generated/1UJTp.jpg" class="portfolio-img w-full border-8 border-red-900" alt="" />
        <img src="https://files.grok.x.ai/generated/YvgNz.jpg" class="portfolio-img w-full border-8 border-red-900" alt="" />
        <img src="https://files.grok.x.ai/generated/1V5db.jpg" class="portfolio-img w-full border-8 border-red-900" alt="" />
      </div>
    </div>
  </section>

  <!-- МОИ ПРОЕКТЫ -->
  <section id="projects" class="py-24 md:py-32 border-t-8 border-red-900 bg-black relative">
    <div class="chain top-[-40px] right-[-20px] opacity-5">⛓</div>
    <div class="max-w-6xl mx-auto px-6 relative z-10">

      <h2 class="text-6xl md:text-8xl font-black text-center mb-20 text-red-700">
        <span class="ru">МОИ ПРОЕКТЫ</span>
        <span class="de">MEINE PROJEKTE</span>
      </h2>

      <div class="grid md:grid-cols-2 gap-8">

        <div class="project-card">
          <h3 class="text-4xl font-black mb-4">DARK KINK SESSIONS</h3>
          <p class="text-xl leading-relaxed text-gray-300">
            <span class="ru">Живые тату-сессии на кинк-вечеринках под красный свет и тяжёлый бас.</span>
            <span class="de">Live-Tattoo-Sessions auf Kink-Partys unter rotem Licht und schwerem Bass.</span>
          </p>
        </div>

        <div class="project-card">
          <h3 class="text-4xl font-black mb-4">BASEMENT RAVE TATTOO</h3>
          <p class="text-xl leading-relaxed text-gray-300">
            <span class="ru">Мобильная тату-станция в сквотах и подвалах до самого утра.</span>
            <span class="de">Mobile Tattoo-Station in Squats und Kellern bis in den frühen Morgen.</span>
          </p>
        </div>

        <div class="project-card">
          <h3 class="text-4xl font-black mb-4">FETISH FLASH NIGHT</h3>
          <p class="text-xl leading-relaxed text-gray-300">
            <span class="ru">Специальные флеш-дизайны для BDSM-сессий и fetish-вечеринок.</span>
            <span class="de">Spezielle Flash-Designs für BDSM-Sessions und Fetisch-Partys.</span>
          </p>
        </div>

        <div class="project-card">
          <h3 class="text-4xl font-black mb-4">AFTERPARTY CHAOS</h3>
          <p class="text-xl leading-relaxed text-gray-300">
            <span class="ru">Тату после основных вечеринок, когда все уже на грани.</span>
            <span class="de">Tattoos nach den Hauptpartys, wenn alle schon am Limit sind.</span>
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- BOOKING -->
  <section id="booking"
    class="py-28 md:py-36 border-t-8 border-red-900 bg-red-900 text-center relative overflow-hidden">

    <div class="absolute inset-0 opacity-20">
      <div class="chain top-0 left-0">⛓</div>
      <div class="chain bottom-[-100px] right-[-50px] rotate-12">⛓</div>
    </div>

    <div class="max-w-4xl mx-auto px-6 relative z-10">

      <h2 class="text-6xl md:text-8xl font-black mb-10">
        <span class="ru">ЗАПИСАТЬСЯ</span>
        <span class="de">SESSION BUCHEN</span>
      </h2>

      <p class="text-3xl md:text-4xl mb-14 leading-tight">
        <span class="ru">Не ищи лёгких путей.<br />Если готов к настоящей метке — пиши.</span>
        <span class="de">Suche nicht den einfachen Weg.<br />Wenn du bereit bist für ein echtes Zeichen — schreib.</span>
      </p>

      <div class="flex flex-col sm:flex-row gap-6 justify-center items-center">
        <a href="https://t.me/namenlostattoo" target="_blank" rel="noopener"
          class="btn-chaos inline-flex items-center gap-3 border-8 border-black bg-white text-black text-3xl font-black py-8 px-14 hover:bg-black hover:text-white transition-all duration-300">
          <i class="fa-brands fa-telegram"></i>
          <span class="ru">TELEGRAM →</span>
          <span class="de">TELEGRAM →</span>
        </a>
        <a href="https://ig.me/m/namenlos_tattoo" target="_blank" rel="noopener"
          class="btn-chaos inline-flex items-center gap-3 border-8 border-black bg-transparent text-white text-3xl font-black py-8 px-14 hover:bg-black transition-all duration-300">
          <i class="fa-brands fa-instagram"></i>
          DIRECT →
        </a>
      </div>

    </div>
  </section>

</Layout>
