---
const year = new Date().getFullYear();
const links = [
  { label: 'About', href: '#about' },
  { label: 'Events', href: '#events' },
  { label: 'Portfolio', href: '#portfolio' },
  { label: 'Rider', href: '#backstage' },
  { label: 'Pricing', href: '#pricing' },
  { label: 'Booking', href: '#booking' },
];
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <a href="/" class="footer__logo" aria-label="Back to top">NAMENLOS</a>
      <p class="footer__tagline">Sound in the dark.</p>
    </div>

    <nav class="footer__nav" aria-label="Footer navigation">
      <ul class="footer__nav-list">
        {links.map(({ label, href }) => (
          <li><a href={href} class="footer__nav-link">{label}</a></li>
        ))}
      </ul>
    </nav>
  </div>

  <div class="container footer__bottom">
    <p class="footer__copy">© {year} NAMENLOS. All rights reserved.</p>
    <p class="footer__legal">
      <a href="#">Privacy</a>
    </p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-lg);
    padding-bottom: var(--space-md);
  }

  .footer__inner {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-lg);
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--color-border);
  }

  .footer__logo {
    font-size: 1.5rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    display: block;
    margin-bottom: 0.5rem;
  }

  .footer__tagline {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .footer__nav-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 2rem;
    justify-content: flex-end;
  }

  .footer__nav-link {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    transition: color var(--transition);
  }

  .footer__nav-link:hover {
    color: var(--color-text);
  }

  .footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: var(--space-md);
    gap: 1rem;
    flex-wrap: wrap;
  }

  .footer__copy,
  .footer__legal a {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .footer__legal a:hover {
    color: var(--color-text);
  }

  @media (max-width: 600px) {
    .footer__inner {
      flex-direction: column;
    }

    .footer__nav-list {
      justify-content: flex-start;
    }
  }
</style>
