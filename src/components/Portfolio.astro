---
interface Work {
  src: string;
  title: string;
  category: string;
  year: number;
}

const works: Work[] = [
  { src: '/artist.jpg', title: 'Voids', category: 'Album art', year: 2025 },
  { src: '/artist1.jpg', title: 'Tension / Release', category: 'Live visual', year: 2024 },
  { src: '/artist.jpg', title: 'Stasis', category: 'Installation', year: 2024 },
  { src: '/artist1.jpg', title: 'Signal Loss', category: 'EP art', year: 2023 },
  { src: '/artist.jpg', title: 'Infrastructure', category: 'Live set film', year: 2023 },
  { src: '/artist1.jpg', title: 'Unnamed 001', category: 'Cassette cover', year: 2022 },
];
---

<section class="section" id="portfolio" aria-labelledby="portfolio-title">
  <div class="container">
    <p class="section-label">Works</p>
    <h2 class="section-title" id="portfolio-title">Selected projects</h2>

    <div class="portfolio__grid">
      {works.map((work) => (
        <article class="work-card">
          <div class="work-card__image-wrap">
            <img
              src={work.src}
              alt={work.title}
              class="work-card__image"
              loading="lazy"
              width="400"
              height="500"
            />
            <div class="work-card__overlay" aria-hidden="true">
              <span class="work-card__category">{work.category}</span>
            </div>
          </div>
          <div class="work-card__meta">
            <p class="work-card__title">{work.title}</p>
            <p class="work-card__year">{work.year}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .portfolio__grid {
    margin-top: var(--space-lg);
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .work-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .work-card__image-wrap {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-md);
    aspect-ratio: 4 / 5;
    background: var(--color-surface);
  }

  .work-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 400ms ease;
    filter: grayscale(20%);
  }

  .work-card:hover .work-card__image {
    transform: scale(1.04);
  }

  .work-card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(10,10,10,0.8) 0%, transparent 50%);
    display: flex;
    align-items: flex-end;
    padding: 1rem;
    opacity: 0;
    transition: opacity var(--transition);
  }

  .work-card:hover .work-card__overlay {
    opacity: 1;
  }

  .work-card__category {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .work-card__meta {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }

  .work-card__title {
    font-size: 0.9375rem;
    font-weight: 600;
  }

  .work-card__year {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 900px) {
    .portfolio__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .portfolio__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
