---
const works = [
  { src: '/images/portfolio/chest1.jpg', title: 'Chest Piece' },
  { src: '/images/portfolio/chest2.jpg', title: 'Dark Ritual' },
  { src: '/images/portfolio/skull.jpg', title: 'Skull Chaos' },
  { src: '/images/portfolio/bird.jpg', title: 'Raven' },
  { src: '/images/portfolio/shoulder.jpg', title: 'Shoulder Blade' },
  { src: '/images/portfolio/hand.jpg', title: 'Hand of Pain' },
];
---

<section id="portfolio" class="section">
  <div class="container">
    <p class="section-label">Портфолио</p>
    <h2 class="section-title">Работы</h2>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {works.map(work => (
        <div class="group relative overflow-hidden rounded-3xl aspect-[4/5] border border-gray-800">
          <img 
            src={work.src} 
            alt={work.title}
            class="w-full h-full object-cover transition-all duration-700 group-hover:scale-110" 
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/30 to-transparent opacity-80 group-hover:opacity-100 transition-all"></div>
          
          <div class="absolute bottom-8 left-8 right-8">
            <p class="text-xl font-bold">{work.title}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .portfolio__grid {
    margin-top: var(--space-lg);
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .work-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .work-card__image-wrap {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-md);
    aspect-ratio: 4 / 5;
    background: var(--color-surface);
  }

  .work-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 400ms ease;
    filter: grayscale(20%);
  }

  .work-card:hover .work-card__image {
    transform: scale(1.04);
  }

  .work-card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(10,10,10,0.8) 0%, transparent 50%);
    display: flex;
    align-items: flex-end;
    padding: 1rem;
    opacity: 0;
    transition: opacity var(--transition);
  }

  .work-card:hover .work-card__overlay {
    opacity: 1;
  }

  .work-card__category {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .work-card__meta {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }

  .work-card__title {
    font-size: 0.9375rem;
    font-weight: 600;
  }

  .work-card__year {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 900px) {
    .portfolio__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .portfolio__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
