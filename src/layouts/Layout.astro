---
interface Props {
  title?: string;
}
const { title = 'NAMENLOS TATTOO • PAIN • CHAOS • ANARCHY' } = Astro.props;
---

<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>

  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" />

  <style>
    @import url('https://fonts.googleapis.com/css2?family=Creepster&display=swap');

    body {
      font-family: 'Impact', system-ui, sans-serif;
      background:
        #0a0a0a
        url('https://images.unsplash.com/photo-1558591710-4b4a1ae0f04d')
        fixed center / cover;
      background-blend-mode: multiply;
      color: #ddd;
    }

    .punk-title {
      font-family: 'Creepster', cursive;
      text-shadow: 6px 6px 0 #000, -4px -4px 0 #000;
      letter-spacing: -4px;
      color: #ff0022;
    }

    .trash-bg {
      background: rgba(20, 0, 0, 0.92);
      border: 6px solid #c00;
      box-shadow: 0 0 0 10px #000;
    }
  </style>
</head>
<body class="overflow-x-hidden">

  <!-- HEADER -->
  <header class="fixed top-0 w-full border-b-8 border-red-800 bg-black/95 z-50 py-5">
    <div class="max-w-7xl mx-auto px-6 flex justify-between items-center">
      <a href="/" class="punk-title text-5xl md:text-6xl">NAMENLOS</a>
      <nav class="hidden md:flex gap-10 text-xl font-black uppercase">
        <a href="#about" class="hover:text-yellow-400">ABOUT ME</a>
        <a href="#portfolio" class="hover:text-yellow-400">PORTFOLIO</a>
        <a href="#projects" class="hover:text-yellow-400">МОИ ПРОЕКТЫ</a>
        <a href="#booking" class="text-red-500 hover:text-white">ЗАПИСАТЬСЯ</a>
      </nav>
    </div>
  </header>

  <slot />

  <!-- FOOTER -->
  <footer class="py-16 text-center border-t-8 border-red-800 bg-black text-red-500 text-xl font-black">
    © 2026 NAMENLOS TATTOO • CHAOS ON SKIN • NO RULES • NO REGRETS
  </footer>

</body>
</html>
